{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alirezasafaei-dev/awesome-free-llm-apis-ir/schema/provider-content.schema.json",
  "title": "Editorial content for a provider page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "provider_id",
    "intent_fa",
    "signup_steps_fa",
    "first_request",
    "common_errors",
    "when_not_to_use_fa",
    "related_guides",
    "last_reviewed"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "provider_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "intent_fa": { "type": "string", "minLength": 80 },
    "signup_steps_fa": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 8 }
    },
    "first_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "code", "notes_fa", "source_url", "checked_at"],
      "properties": {
        "language": { "enum": ["curl", "python", "javascript"] },
        "code": { "type": "string", "minLength": 20 },
        "notes_fa": { "type": "string", "minLength": 20 },
        "source_url": { "type": "string", "format": "uri" },
        "checked_at": { "type": "string", "format": "date" }
      }
    },
    "common_errors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "title_fa", "resolution_fa"],
        "properties": {
          "code": { "type": "string", "minLength": 2 },
          "title_fa": { "type": "string", "minLength": 12 },
          "resolution_fa": { "type": "string", "minLength": 12 },
          "source_url": { "type": "string", "format": "uri" },
          "checked_at": { "type": "string", "format": "date" }
        },
        "dependentRequired": {
          "source_url": ["checked_at"],
          "checked_at": ["source_url"]
        }
      }
    },
    "when_not_to_use_fa": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 8 }
    },
    "related_guides": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
    },
    "last_reviewed": { "type": "string", "format": "date" }
  }
}
