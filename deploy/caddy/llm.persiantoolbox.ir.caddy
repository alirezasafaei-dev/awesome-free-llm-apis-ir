llm.persiantoolbox.ir {
	encode zstd gzip
	root * /srv/awesome-free-llm-apis-ir/current

	# Preserve route order: Caddy normally sorts try_files before handle, which
	# would turn analytics POSTs into the static 404 page before proxying them.
	route {
		handle /api/event {
			reverse_proxy 127.0.0.1:8002
		}

		handle {
			try_files {path} {path}/ =404
			file_server
		}
	}

	@catalog path /catalog.json
	header @catalog Cache-Control "public, max-age=300, must-revalidate"
	@buildmeta path /build-meta.json
	header @buildmeta Cache-Control "no-store"
	@static path *.js *.css *.png *.svg *.webmanifest
	header @static Cache-Control "public, max-age=31536000, immutable"
	@index path / /index.html
	header @index Cache-Control "no-cache, must-revalidate"
	@sitemap path /sitemap.xml /robots.txt /llms.txt
	header @sitemap Cache-Control "public, max-age=300, must-revalidate"
	@notfound path /404.html
	header @notfound Cache-Control "no-store"

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests"
	}

	handle_errors {
		rewrite * /404.html
		file_server
	}

	log {
		output file /var/log/caddy/llm.persiantoolbox.ir.access.log
		format json
	}
}
