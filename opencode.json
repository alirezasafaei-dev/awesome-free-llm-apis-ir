{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "share": "disabled",
  "lsp": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "reports/local/**": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "question": "allow",
    "websearch": "allow",
    "webfetch": "ask",
    "edit": "ask",
    "task": "ask",
    "skill": "ask",
    "external_directory": "deny",
    "doom_loop": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git rev-parse*": "allow",
      "git remote -v*": "allow",
      "git branch --show-current*": "allow",
      "npm test*": "allow",
      "npm run launch:links:test*": "allow",
      "npm run launch:log:test*": "allow",
      "npm run privacy:test*": "allow",
      "git fetch*": "ask",
      "git switch*": "ask",
      "git checkout*": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "gh pr create*": "ask",
      "gh issue comment*": "ask",
      "npm ci*": "ask",
      "npm run site:build*": "ask",
      "git push --force*": "deny",
      "git push * main*": "deny",
      "git push * master*": "deny",
      "git merge*": "deny",
      "git rebase*": "deny",
      "git reset --hard*": "deny",
      "git clean -f*": "deny",
      "gh pr merge*": "deny",
      "gh release create*": "deny",
      "gh issue close*": "deny",
      "gh pr close*": "deny",
      "npm run deploy*": "deny",
      "ssh *": "deny",
      "scp *": "deny",
      "rsync *": "deny",
      "rm -rf*": "deny"
    }
  }
}
