# Copy to .env. Never commit .env or real credentials.
IR_TEST_COUNTRY=IR
IR_TEST_ROUTE=direct
IR_TEST_EXIT_COUNTRY=IR
IR_TEST_VPN_PROVIDER=
IR_TEST_ISP=
IR_TEST_ASN=
IR_TEST_CITY=

# A blocked result may only be promoted to verified_blocked when the same
# credential was independently confirmed valid from a supported region.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_CREDENTIAL_VALIDATED=false

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
