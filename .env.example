FIREWORKS_API_KEY=
FIREWORKS_MODEL=gpt-oss-120b
FIREWORKS_CREDENTIAL_VALIDATED=false

# OVHcloud AI Endpoints: anonymous (no-key) access supported
OVHCLOUD_API_KEY=
OVHCLOUD_MODEL=gpt-oss-20b
OVHCLOUD_CREDENTIAL_VALIDATED=false

# LLM7.io: anonymous (no-key) access supported
LLM7_API_KEY=
LLM7_MODEL=gpt-4o-mini
LLM7_CREDENTIAL_VALIDATED=false

# SiliconFlow: Chinese provider, free models, phone verification required
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B
SILICONFLOW_CREDENTIAL_VALIDATED=false

# ModelScope (Alibaba): Chinese provider, free API-Inference, 2000 RPD
MODELSCOPE_API_KEY=
MODELSCOPE_MODEL=Qwen/Qwen3.5-35B-A3B
MODELSCOPE_CREDENTIAL_VALIDATED=false

# OpenCode Zen: free models, no credit card required
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_MODEL=deepseek-v4-flash-free
OPENCODE_ZEN_CREDENTIAL_VALIDATED=false

# Persian benchmark runner (any OpenAI-compatible endpoint)
BENCHMARK_PROVIDER_ID=
BENCHMARK_API_BASE_URL=
BENCHMARK_API_KEY=
BENCHMARK_MODEL=
