{
  "name": "awesome-free-llm-apis-ir",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Verified, machine-readable catalog of free LLM APIs for Persian speakers and users in Iran.",
  "scripts": {
    "validate": "node scripts/validate.mjs",
    "generate": "node scripts/generate-readme.mjs && node scripts/generate-catalog.mjs",
    "generate:check": "node scripts/generate-readme.mjs --check",
    "catalog:check": "node scripts/generate-catalog.mjs --check",
    "check:freshness": "node scripts/check-freshness.mjs --strict",
    "site:build": "node scripts/build-site.mjs",
    "site:check": "node scripts/check-site.mjs",
    "deploy:check": "node scripts/check-deploy.mjs",
    "deploy:test": "node scripts/test-deploy-release.mjs",
    "benchmark:validate": "node scripts/validate-benchmark.mjs",
    "benchmark:dry": "node scripts/run-persian-benchmark.mjs --dry-run",
    "benchmark:test": "node scripts/test-benchmark-runner.mjs",
    "benchmark:run": "node scripts/run-persian-benchmark.mjs",
    "check:links": "node scripts/check-links.mjs",
    "verify:iran": "node scripts/verify-from-iran.mjs",
    "verify:iran:dry": "node scripts/verify-from-iran.mjs --dry-run",
    "advisor:test": "node scripts/test-advisor-scoring.mjs",
    "test": "npm run validate && npm run generate:check && npm run catalog:check && npm run verify:iran:dry && npm run advisor:test && npm run benchmark:validate && npm run benchmark:dry && npm run benchmark:test && npm run site:check && npm run deploy:check && npm run deploy:test"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
